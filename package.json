{
  "name": "open-links",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.9",
  "workspaces": ["packages/*"],
  "scripts": {
    "ci:required:typecheck": "bun run typecheck",
    "ci:required:deploy": "bun run test:deploy",
    "ci:required:build": "bun run build",
    "ci:required:quality": "bun run quality:check",
    "ci:required:studio-integration": "bun run studio:test:integration",
    "ci:required": "bun run ci:required:typecheck && bun run ci:required:deploy && bun run ci:required:build && bun run ci:required:quality && bun run ci:required:studio-integration",
    "audit:fetch-cache": "bun test scripts/fetch-cache-audit.test.ts",
    "ci:required:hook:build": "bun run public:clean && bun run social:preview:generate && bun run validate:data:hook && bun run badge:site && vite build",
    "ci:required:hook:quality": "bun scripts/quality/run-quality-checks.ts --exclude-domain performance --report .cache/openlinks-precommit/quality-report.json --summary .cache/openlinks-precommit/quality-report.md",
    "ci:required:docker:api": "docker build -f packages/studio-api/Dockerfile .",
    "ci:required:docker:web": "docker build -f packages/studio-web/Dockerfile .",
    "ci:required:docker:worker": "docker build -f packages/studio-worker/Dockerfile .",
    "ci:required:docker": "bun run ci:required:docker:api && bun run ci:required:docker:web && bun run ci:required:docker:worker",
    "ci:strict": "bun run build:strict && bun run quality:strict:ci",
    "avatar:sync": "bun scripts/sync-profile-avatar.ts",
    "images:sync": "bun scripts/sync-content-images.ts",
    "social:preview:generate": "bun scripts/generate-site-social-preview.ts",
    "predev": "bun run public:clean && bun run avatar:sync && bun run enrich:rich:strict && bun run images:sync && bun run social:preview:generate && bun run badge:site",
    "prepare": "husky",
    "hooks:precommit": "bash scripts/hooks/pre-commit.sh",
    "dev": "vite",
    "build": "vite build",
    "build:strict": "bun run public:clean && bun run avatar:sync && bun run enrich:rich:strict && bun run images:sync && bun run social:preview:generate && bun run validate:data:strict && bun run badge:site && vite build",
    "prebuild": "bun run public:clean && bun run avatar:sync && bun run enrich:rich:strict && bun run images:sync && bun run social:preview:generate && bun run validate:data && bun run badge:site",
    "badge:site": "bun scripts/generate-site-badge.ts",
    "branding:assets": "bun scripts/generate-openlinks-brand-assets.ts",
    "openclaw:prompts:sync": "bun scripts/sync-openclaw-prompts.ts",
    "openclaw:prompts:check": "bun scripts/sync-openclaw-prompts.ts --check",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test:deploy": "bun test src/lib/deployment-config.test.ts scripts/lib/build-timestamp.test.ts scripts/lib/deploy-artifact.test.ts scripts/lib/aws-deploy.test.ts scripts/lib/deploy-setup.test.ts scripts/enrichment/generated-metadata.test.ts scripts/clean-public-build-artifacts.test.ts",
    "test:playwright:payment-qr": "playwright test tests/playwright/payment-qr.spec.ts",
    "test:playwright:payment-qr:update": "playwright test tests/playwright/payment-qr.spec.ts --update-snapshots",
    "payment:effects:screenshots": "bun scripts/generate-payment-card-effect-screenshots.ts",
    "payment:effects:videos": "bun scripts/generate-payment-card-effect-videos.ts",
    "public:clean": "bun scripts/clean-public-build-artifacts.ts",
    "deploy:build": "bun run scripts/deploy/build.ts",
    "deploy:build:aws": "bun run scripts/deploy/build.ts --target=aws",
    "deploy:build:pages": "bun run scripts/deploy/build.ts --target=github-pages",
    "deploy:setup": "bun run scripts/deploy/setup.ts",
    "deploy:setup:aws": "bun run scripts/deploy/setup-aws.ts",
    "deploy:setup:github": "bun run scripts/deploy/setup-github.ts",
    "deploy:aws:bootstrap": "bun run scripts/deploy/bootstrap-aws.ts",
    "deploy:aws:publish": "bun run scripts/deploy/publish-aws.ts",
    "deploy:pages:plan": "bun run scripts/deploy/plan-pages.ts",
    "deploy:verify": "bun run scripts/deploy/verify.ts",
    "bootstrap:linktree": "bun scripts/bootstrap-linktree.ts",
    "biome:check": "bunx @biomejs/biome check . --files-ignore-unknown=true",
    "biome:fix": "bunx @biomejs/biome check . --write --files-ignore-unknown=true",
    "biome:staged:fix": "bunx @biomejs/biome check --staged --write --files-ignore-unknown=true --no-errors-on-unmatched",
    "enrich:rich": "bun scripts/enrich-rich-links.ts",
    "enrich:rich:write-cache": "bun scripts/enrich-rich-links.ts --write-public-cache",
    "enrich:rich:strict": "bun scripts/enrich-rich-links.ts --strict",
    "enrich:rich:strict:write-cache": "bun scripts/enrich-rich-links.ts --strict --write-public-cache",
    "public:rich:sync": "bun scripts/public-rich-sync.ts",
    "followers:history:sync": "bun scripts/sync-follower-history.ts",
    "linkedin:debug:bootstrap": "bun scripts/oneoff/linkedin-debug-bootstrap.ts",
    "linkedin:debug:login": "bun scripts/oneoff/linkedin-login-session.ts",
    "linkedin:debug:validate": "bun scripts/oneoff/linkedin-metadata-validate.ts",
    "linkedin:debug:validate:cookie-bridge": "bun scripts/oneoff/linkedin-metadata-validate.ts --cookie-bridge-check",
    "auth:flow:assist": "bun scripts/oneoff/auth-flow-assist.ts",
    "auth:rich:sync": "bun scripts/sync-authenticated-rich-cache.ts",
    "auth:rich:clear": "bun scripts/clear-authenticated-rich-cache.ts",
    "setup:rich-auth": "bun scripts/sync-authenticated-rich-cache.ts --only-missing",
    "auth:extractor:new": "bun scripts/authenticated-extractors/scaffold-extractor.ts",
    "quality:check": "bun scripts/quality/run-quality-checks.ts",
    "quality:required": "bun run quality:check",
    "quality:embedded-code": "bun scripts/quality/check-embedded-code.ts",
    "quality:strict": "bun run quality:embedded-code && bun scripts/quality/run-quality-checks.ts --strict",
    "quality:strict:ci": "bun run quality:embedded-code && bun scripts/quality/run-quality-checks.ts --strict --warn-only-domain performance",
    "quality:signal": "bun run quality:strict",
    "quality:json": "bun scripts/quality/run-quality-checks.ts --format json",
    "quality:strict:json": "bun scripts/quality/run-quality-checks.ts --strict --format json",
    "validate:data": "bun scripts/validate-data.ts",
    "validate:data:hook": "bun scripts/validate-data.ts --mode hook --changed-paths-file .cache/openlinks-precommit/staged-files.txt",
    "validate:data:strict": "bun scripts/validate-data.ts --strict",
    "validate:data:json": "bun scripts/validate-data.ts --format json",
    "studio:install": "bun install",
    "studio:web:dev": "bun run --filter @openlinks/studio-web dev",
    "studio:api:dev": "bun run --filter @openlinks/studio-api dev",
    "studio:worker:dev": "bun run --filter @openlinks/studio-worker dev",
    "studio:web:test": "bun run --filter @openlinks/studio-web test",
    "studio:web:build": "bun run --filter @openlinks/studio-web build",
    "studio:api:build": "bun run --filter @openlinks/studio-api build",
    "studio:worker:build": "bun run --filter @openlinks/studio-worker build",
    "studio:env:check:prod": "bun scripts/studio/validate-prod-env.ts --target all --env-file .env.studio",
    "studio:web:build:prod": "bun run studio:env:check:prod -- --target web && bun run studio:web:build",
    "studio:api:build:prod": "bun run studio:env:check:prod -- --target api && bun run studio:api:build",
    "studio:worker:build:prod": "bun run studio:env:check:prod -- --target worker && bun run studio:worker:build",
    "studio:build:prod": "bun run studio:web:build:prod && bun run studio:api:build:prod && bun run studio:worker:build:prod",
    "studio:db:migrate": "bun run --filter @openlinks/studio-api db:migrate",
    "studio:test:integration": "bun run --filter @openlinks/studio-api test:integration",
    "studio:typecheck": "bun run --filter @openlinks/studio-shared typecheck && bun run --filter @openlinks/studio-api typecheck && bun run --filter @openlinks/studio-web typecheck && bun run --filter @openlinks/studio-worker typecheck",
    "studio:lint": "bunx @biomejs/biome lint packages docs/studio-self-serve.md",
    "studio:format": "bunx @biomejs/biome format --write packages docs/studio-self-serve.md",
    "studio:format:check": "bunx @biomejs/biome format packages docs/studio-self-serve.md",
    "studio:fix": "bunx @biomejs/biome check --write packages docs/studio-self-serve.md",
    "studio:check": "bun run studio:typecheck && bun run studio:lint && bun run studio:format:check && bun run studio:web:test && bun run studio:test:integration"
  },
  "dependencies": {
    "@kobalte/core": "0.13.11",
    "echarts": "^6.0.0",
    "qr-code-styling": "^1.9.2",
    "simple-icons": "^15.22.0",
    "solid-js": "^1.9.11",
    "solid-sonner": "0.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.58.2",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^25.3.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "badge-maker": "^5.0.2",
    "husky": "^9.1.7",
    "png-to-ico": "^3.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-solid": "^2.11.10"
  }
}
