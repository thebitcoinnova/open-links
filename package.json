{
  "name": "open-links",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ci:required": "npm run validate:data && npm run typecheck && npm run build",
    "ci:strict": "npm run validate:data:strict && npm run build:strict",
    "dev": "vite",
    "build": "vite build",
    "build:strict": "npm run enrich:rich:strict && npm run validate:data:strict && vite build",
    "prebuild": "npm run enrich:rich && npm run validate:data",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "enrich:rich": "tsx scripts/enrich-rich-links.ts",
    "enrich:rich:strict": "tsx scripts/enrich-rich-links.ts --strict",
    "validate:data": "tsx scripts/validate-data.ts",
    "validate:data:strict": "tsx scripts/validate-data.ts --strict",
    "validate:data:json": "tsx scripts/validate-data.ts --format json"
  },
  "dependencies": {
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-solid": "^2.11.10"
  }
}
