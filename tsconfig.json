{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": true,
    "noEmit": true,
    "types": ["vite/client", "node"],
    "jsx": "preserve",
    "jsxImportSource": "solid-js"
  },
  "include": ["src", "scripts", "vite.config.ts", "data", "schema"]
}
