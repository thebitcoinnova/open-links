{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@openlinks/studio-shared": ["../studio-shared/src/index.ts"],
      "@openlinks/studio-shared/*": ["../studio-shared/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
