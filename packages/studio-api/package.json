{
  "name": "@openlinks/studio-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "bun dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "bun src/db/migrate.ts",
    "lint": "biome check src",
    "format": "biome format --write src",
    "format:check": "biome format --write=false src"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@octokit/rest": "^22.0.1",
    "@openlinks/studio-shared": "file:../studio-shared",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "dotenv": "^16.6.1",
    "fastify": "^5.6.1",
    "pg": "^8.16.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/pg": "^8.15.5",
    "typescript": "^5.9.3"
  }
}
