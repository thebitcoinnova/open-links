{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@openlinks/studio-shared": ["../studio-shared/src/index.ts"],
      "@openlinks/studio-shared/*": ["../studio-shared/src/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
