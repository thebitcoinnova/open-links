{
  "name": "@openlinks/studio-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "bun dist/worker.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check src",
    "format": "biome format --write src",
    "format:check": "biome format --write=false src"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "typescript": "^5.9.3"
  }
}
