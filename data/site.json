{
  "title": "OpenLinks",
  "description": "Personal, free, open source, version-controlled social links website.",
  "theme": {
    "active": "sleek",
    "available": [
      "sleek",
      "sleek-emerald",
      "sleek-mono",
      "midnight",
      "daybreak",
      "neutral",
      "editorial",
      "futuristic",
      "humanist"
    ]
  },
  "ui": {
    "compositionMode": "balanced",
    "groupingStyle": "subtle",
    "profileRichness": "standard",
    "density": "medium",
    "modePolicy": "dark-toggle",
    "linkTarget": "new-tab-external",
    "desktopColumns": "one",
    "typographyScale": "fixed",
    "targetSize": "comfortable",
    "profileAvatarScale": 1.68,
    "brandIcons": {
      "colorMode": "brand",
      "contrastMode": "auto",
      "minContrastRatio": 3,
      "sizeMode": "large"
    },
    "richCards": {
      "renderMode": "auto",
      "sourceLabelDefault": "show",
      "imageTreatment": "cover",
      "imageFit": "contain",
      "mobile": {
        "imageLayout": "inline"
      },
      "enrichment": {
        "enabledByDefault": true,
        "timeoutMs": 4000,
        "retries": 1,
        "metadataPath": "data/generated/rich-metadata.json",
        "reportPath": "data/generated/rich-enrichment-report.json",
        "publicCachePath": "data/cache/rich-public-cache.json"
      }
    },
    "payments": {
      "qr": {
        "displayDefault": "always",
        "styleDefault": "dots",
        "foregroundColorDefault": "#111827",
        "backgroundColorDefault": "#FFFFFF",
        "logoModeDefault": "rail-default",
        "logoSizeDefault": 0.24,
        "fullscreenDefault": "enabled"
      }
    },
    "footer": {
      "description": "OpenLinks is a personal, free, open source, version-controlled links site.\nFork it, customize JSON, and publish fast.",
      "ctaLabel": "Create Your OpenLinks",
      "ctaUrl": "https://github.com/pRizz/open-links",
      "showLastUpdated": true
    }
  },
  "quality": {
    "reportPath": "data/generated/quality-report.json",
    "summaryPath": "data/generated/quality-report.md",
    "blockingDomains": ["seo", "accessibility", "performance"],
    "seo": {
      "canonicalBaseUrl": "https://prizz.github.io/open-links/",
      "socialImageFallback": "/openlinks-social-fallback.svg",
      "defaults": {
        "title": "OpenLinks",
        "description": "Personal, free, open source, version-controlled social links website.",
        "twitterCard": "summary_large_image"
      },
      "overrides": {
        "profile": {
          "ogType": "website"
        }
      }
    },
    "accessibility": {
      "focusContrastStrict": true,
      "manualSmokeChecks": [
        "Keyboard navigation reaches utility controls, profile, and links in expected order.",
        "Theme toggle announces current mode change clearly for screen readers.",
        "Simple cards expose explicit action labels and are keyboard activatable.",
        "Rich cards expose explicit action labels and are keyboard activatable."
      ]
    },
    "performance": {
      "routes": ["/"],
      "profiles": {
        "mobile": {
          "totalBytes": { "warn": 280000, "fail": 380000 },
          "jsBytes": { "warn": 200000, "fail": 280000 },
          "cssBytes": { "warn": 45000, "fail": 70000 },
          "htmlBytes": { "warn": 18000, "fail": 26000 },
          "largestAssetBytes": { "warn": 999999999, "fail": 999999999 },
          "minimumScore": { "warn": 1, "fail": 1 }
        },
        "desktop": {
          "totalBytes": { "warn": 340000, "fail": 440000 },
          "jsBytes": { "warn": 240000, "fail": 320000 },
          "cssBytes": { "warn": 55000, "fail": 80000 },
          "htmlBytes": { "warn": 22000, "fail": 32000 },
          "largestAssetBytes": { "warn": 210000, "fail": 290000 },
          "minimumScore": { "warn": 90, "fail": 75 }
        }
      }
    }
  },
  "baseUrl": "/",
  "custom": {
    "heroStyle": "sleek-cards"
  }
}
