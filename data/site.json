{
  "$schema": "https://open-links.dev/schema/site.schema.json",
  "baseUrl": "/",
  "custom": {
    "preset": "default"
  },
  "description": "Host of Bitcoin Nova Podcast | X Community Leader",
  "sharing": {
    "vcard": {
      "enabled": true,
      "filename": "staci-costopoulos.vcf",
      "fields": {
        "email": "TheBitcoinNova@gmail.com",
        "organization": "The Bitcoin Nova",
        "title": "Host of Bitcoin Nova Podcast",
        "role": "Bitcoin educator, podcast host, and community builder",
        "note": "X Community Leader"
      },
      "include": {
        "photo": true,
        "profileUrl": true,
        "linkIds": ["the-bitcoin-nova", "youtube", "x", "the-bitcoin-nova-x"],
        "customUrls": [
          {
            "label": "Spotify",
            "url": "https://open.spotify.com/show/TheBitcoinNova"
          },
          {
            "label": "TikTok",
            "url": "https://tiktok.com/@bitcoinnova"
          },
          {
            "label": "Apple Podcasts",
            "url": "https://podcasts.apple.com/us/podcast/the-bitcoin-nova-podcast/id1800522855"
          }
        ]
      }
    }
  },
  "quality": {
    "seo": {
      "canonicalBaseUrl": "https://links.thebitcoinnova.com/",
      "defaults": {
        "description": "Host of Bitcoin Nova Podcast, Bitcoin educator, and community leader sharing shows, links, and projects.",
        "title": "Staci Costopoulos | Bitcoin educator, podcast host, and community builder"
      },
      "socialImageFallback": "/generated/seo/social-preview.png"
    }
  },
  "theme": {
    "active": "sleek",
    "available": ["sleek", "daybreak", "sleek-emerald", "sleek-mono"]
  },
  "title": "Staci Costopoulos | OpenLinks",
  "ui": {
    "compositionMode": "balanced",
    "density": "medium",
    "desktopColumns": "one",
    "footer": {
      "ctaLabel": "Create Your OpenLinks",
      "description": "OpenLinks is a personal, free, open source, version-controlled links site.\nFork it, customize it, and publish fast.",
      "prompt": {
        "enabled": true,
        "explanation": "Paste this bootstrap prompt into OpenClaw, Claude, or Codex to create a new OpenLinks site from this repository.",
        "title": "Create your own OpenLinks site"
      },
      "showBuildInfo": true
    },
    "groupingStyle": "subtle",
    "linkTarget": "new-tab-external",
    "modePolicy": "dark-toggle",
    "profileRichness": "rich",
    "targetSize": "comfortable",
    "typographyScale": "fixed"
  }
}
