{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-links.dev/schema/rich-authenticated-cache.schema.json",
  "title": "OpenLinks Authenticated Rich Metadata Cache",
  "type": "object",
  "required": ["version", "updatedAt", "entries"],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "entries": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "object",
        "required": [
          "extractorId",
          "linkId",
          "sourceUrl",
          "capturedAt",
          "metadata",
          "assets",
          "diagnostics"
        ],
        "properties": {
          "extractorId": {
            "type": "string",
            "minLength": 1
          },
          "linkId": {
            "type": "string",
            "minLength": 1
          },
          "sourceUrl": {
            "type": "string",
            "format": "uri"
          },
          "capturedAt": {
            "type": "string",
            "format": "date-time"
          },
          "metadata": {
            "type": "object",
            "required": ["title", "description", "image"],
            "properties": {
              "title": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "image": {
                "type": "string",
                "minLength": 1
              },
              "sourceLabel": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          },
          "assets": {
            "type": "object",
            "required": ["image"],
            "properties": {
              "image": {
                "type": "object",
                "required": ["path", "sourceUrl", "contentType", "bytes", "sha256"],
                "properties": {
                  "path": {
                    "type": "string",
                    "minLength": 1
                  },
                  "sourceUrl": {
                    "type": "string",
                    "format": "uri"
                  },
                  "contentType": {
                    "type": "string",
                    "minLength": 1
                  },
                  "bytes": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "sha256": {
                    "type": "string",
                    "pattern": "^[a-f0-9]{64}$"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          "diagnostics": {
            "type": "object",
            "required": [
              "extractorVersion",
              "selectorProfile",
              "placeholderSignals",
              "capturedFromUrl"
            ],
            "properties": {
              "extractorVersion": {
                "type": "string",
                "minLength": 1
              },
              "selectorProfile": {
                "type": "string",
                "minLength": 1
              },
              "placeholderSignals": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "capturedFromUrl": {
                "type": "string",
                "format": "uri"
              },
              "notes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
