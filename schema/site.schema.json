{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-links.dev/schema/site.schema.json",
  "title": "OpenLinks Site Config",
  "type": "object",
  "required": ["title", "description", "theme"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "baseUrl": {
      "type": "string",
      "minLength": 1
    },
    "theme": {
      "type": "object",
      "required": ["active", "available"],
      "properties": {
        "active": {
          "type": "string",
          "minLength": 1
        },
        "available": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    },
    "custom": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
