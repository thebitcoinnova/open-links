{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-links.dev/schema/site.schema.json",
  "title": "OpenLinks Site Config",
  "type": "object",
  "required": ["title", "description", "theme"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "baseUrl": {
      "type": "string",
      "minLength": 1
    },
    "theme": {
      "type": "object",
      "required": ["active", "available"],
      "properties": {
        "active": {
          "type": "string",
          "minLength": 1
        },
        "available": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    },
    "ui": {
      "type": "object",
      "properties": {
        "compositionMode": {
          "type": "string",
          "enum": ["balanced", "identity-first", "links-first", "links-only"]
        },
        "groupingStyle": {
          "type": "string",
          "enum": ["subtle", "none", "bands"]
        },
        "profileRichness": {
          "type": "string",
          "enum": ["minimal", "standard", "rich"]
        },
        "density": {
          "type": "string",
          "enum": ["compact", "medium", "spacious"]
        },
        "modePolicy": {
          "type": "string",
          "enum": ["dark-toggle", "static-dark", "static-light"]
        },
        "linkTarget": {
          "type": "string",
          "enum": ["new-tab-external", "same-tab", "new-tab-all"]
        },
        "desktopColumns": {
          "type": "string",
          "enum": ["one", "two"]
        },
        "typographyScale": {
          "type": "string",
          "enum": ["fixed", "compact", "expressive"]
        },
        "targetSize": {
          "type": "string",
          "enum": ["comfortable", "compact", "large"]
        }
      },
      "additionalProperties": true
    },
    "custom": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
