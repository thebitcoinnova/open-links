{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-links.dev/schema/site.schema.json",
  "title": "OpenLinks Site Config",
  "type": "object",
  "required": ["title", "description", "theme"],
  "$defs": {
    "seoMetadataFields": {
      "type": "object",
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "canonical": { "type": "string", "minLength": 1 },
        "ogTitle": { "type": "string", "minLength": 1 },
        "ogDescription": { "type": "string", "minLength": 1 },
        "ogType": { "type": "string", "minLength": 1 },
        "ogImage": { "type": "string", "minLength": 1 },
        "ogUrl": { "type": "string", "minLength": 1 },
        "twitterCard": { "type": "string", "minLength": 1 },
        "twitterTitle": { "type": "string", "minLength": 1 },
        "twitterDescription": { "type": "string", "minLength": 1 },
        "twitterImage": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "budgetThreshold": {
      "oneOf": [
        { "type": "number", "minimum": 1 },
        {
          "type": "object",
          "required": ["warn", "fail"],
          "properties": {
            "warn": { "type": "number", "minimum": 1 },
            "fail": { "type": "number", "minimum": 1 }
          },
          "additionalProperties": false
        }
      ]
    },
    "performanceProfileBudget": {
      "type": "object",
      "properties": {
        "totalBytes": { "$ref": "#/$defs/budgetThreshold" },
        "jsBytes": { "$ref": "#/$defs/budgetThreshold" },
        "cssBytes": { "$ref": "#/$defs/budgetThreshold" },
        "htmlBytes": { "$ref": "#/$defs/budgetThreshold" },
        "largestAssetBytes": { "$ref": "#/$defs/budgetThreshold" },
        "minimumScore": { "$ref": "#/$defs/budgetThreshold" }
      },
      "additionalProperties": true
    }
  },
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "baseUrl": {
      "type": "string",
      "minLength": 1
    },
    "theme": {
      "type": "object",
      "required": ["active", "available"],
      "properties": {
        "active": {
          "type": "string",
          "minLength": 1
        },
        "available": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    },
    "ui": {
      "type": "object",
      "properties": {
        "compositionMode": {
          "type": "string",
          "enum": ["balanced", "identity-first", "links-first", "links-only"]
        },
        "groupingStyle": {
          "type": "string",
          "enum": ["subtle", "none", "bands"]
        },
        "profileRichness": {
          "type": "string",
          "enum": ["minimal", "standard", "rich"]
        },
        "density": {
          "type": "string",
          "enum": ["compact", "medium", "spacious"]
        },
        "modePolicy": {
          "type": "string",
          "enum": ["dark-toggle", "static-dark", "static-light"]
        },
        "linkTarget": {
          "type": "string",
          "enum": ["new-tab-external", "same-tab", "new-tab-all"]
        },
        "desktopColumns": {
          "type": "string",
          "enum": ["one", "two"]
        },
        "typographyScale": {
          "type": "string",
          "enum": ["fixed", "compact", "expressive"]
        },
        "targetSize": {
          "type": "string",
          "enum": ["comfortable", "compact", "large"]
        }
      },
      "additionalProperties": true
    },
    "quality": {
      "type": "object",
      "properties": {
        "reportPath": {
          "type": "string",
          "minLength": 1
        },
        "blockingDomains": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["seo", "accessibility", "performance", "manual-smoke"]
          }
        },
        "seo": {
          "type": "object",
          "properties": {
            "canonicalBaseUrl": {
              "type": "string",
              "minLength": 1
            },
            "socialImageFallback": {
              "type": "string",
              "minLength": 1
            },
            "defaults": {
              "$ref": "#/$defs/seoMetadataFields"
            },
            "overrides": {
              "type": "object",
              "properties": {
                "profile": {
                  "$ref": "#/$defs/seoMetadataFields"
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "accessibility": {
          "type": "object",
          "properties": {
            "focusContrastStrict": {
              "type": "boolean"
            },
            "manualSmokeChecks": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "additionalProperties": true
        },
        "performance": {
          "type": "object",
          "properties": {
            "routes": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "profiles": {
              "type": "object",
              "properties": {
                "mobile": {
                  "$ref": "#/$defs/performanceProfileBudget"
                },
                "desktop": {
                  "$ref": "#/$defs/performanceProfileBudget"
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "custom": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
