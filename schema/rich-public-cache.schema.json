{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-links.dev/schema/rich-public-cache.schema.json",
  "title": "OpenLinks Public Rich Metadata Cache",
  "type": "object",
  "required": ["version", "updatedAt", "entries"],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "entries": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "object",
        "required": ["linkId", "sourceUrl", "capturedAt", "updatedAt", "metadata"],
        "properties": {
          "linkId": {
            "type": "string",
            "minLength": 1
          },
          "sourceUrl": {
            "type": "string",
            "format": "uri"
          },
          "capturedAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "metadata": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "image": {
                "type": "string",
                "minLength": 1
              },
              "profileImage": {
                "type": "string",
                "minLength": 1
              },
              "handle": {
                "type": "string",
                "minLength": 1
              },
              "followersCount": {
                "type": "integer",
                "minimum": 0
              },
              "followersCountRaw": {
                "type": "string",
                "minLength": 1
              },
              "followingCount": {
                "type": "integer",
                "minimum": 0
              },
              "followingCountRaw": {
                "type": "string",
                "minLength": 1
              },
              "subscribersCount": {
                "type": "integer",
                "minimum": 0
              },
              "subscribersCountRaw": {
                "type": "string",
                "minLength": 1
              },
              "sourceLabel": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          },
          "etag": {
            "type": "string",
            "minLength": 1
          },
          "lastModified": {
            "type": "string",
            "minLength": 1
          },
          "cacheControl": {
            "type": "string",
            "minLength": 1
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
