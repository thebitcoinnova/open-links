{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-links.dev/schema/rich-enrichment-blockers.schema.json",
  "title": "OpenLinks Rich Enrichment Blockers Registry",
  "type": "object",
  "required": ["version", "updatedAt", "blockers"],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "status",
          "scope",
          "domains",
          "matchSubdomains",
          "reasonCategory",
          "lastVerifiedAt",
          "summary",
          "remediation",
          "docs"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["blocked", "monitoring", "resolved"]
          },
          "scope": {
            "type": "string",
            "enum": ["direct_fetch"]
          },
          "domains": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "matchSubdomains": {
            "type": "boolean"
          },
          "reasonCategory": {
            "type": "string",
            "enum": ["authwall", "bot_protection", "challenge", "unknown"]
          },
          "lastVerifiedAt": {
            "type": "string",
            "format": "date-time"
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "remediation": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "plannedSupportNote": {
            "type": "string",
            "minLength": 1
          },
          "docs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
