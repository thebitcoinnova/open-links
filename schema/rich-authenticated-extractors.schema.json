{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-links.dev/schema/rich-authenticated-extractors.schema.json",
  "title": "OpenLinks Authenticated Rich Extractors Registry",
  "type": "object",
  "required": ["version", "updatedAt", "extractors"],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "extractors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "status", "method", "domains", "matchSubdomains", "summary", "docs"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["active", "experimental", "disabled"]
          },
          "method": {
            "type": "string",
            "enum": ["manual_browser_session"]
          },
          "domains": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "matchSubdomains": {
            "type": "boolean"
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "loginInstructions": {
            "type": "string",
            "minLength": 1
          },
          "docs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
